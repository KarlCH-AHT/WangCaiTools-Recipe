# ─────────────────────────────────────────────────────────────────────────────
# Family Recipe Planner – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (MySQL / PlanetScale / TiDB) ─────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:password@localhost:3306/recipe_planner

# ── Authentication ────────────────────────────────────────────────────────────
# A long random secret for signing JWT session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# Optional: set this user's openId as admin on first sign-in/upsert.
OWNER_OPEN_ID=

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
# Required for AI recipe generation.
# Works with any OpenAI-compatible API (OpenAI, Azure, Ollama, Together, etc.)
OPENAI_API_KEY=sk-...
# Optional: override the default base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: override the model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── AWS S3 File Storage ────────────────────────────────────────────────────────
# Required for recipe image uploads.
# If not configured, image uploads are skipped (app still works without images).
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...
# Optional: custom CDN or public base URL for uploaded files
# S3_PUBLIC_BASE_URL=https://cdn.example.com
